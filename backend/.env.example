# ----------------------------------------------------------------------------
# Topkapı QR Attendance - Backend Environment Configuration
# Copy this file to ".env" and adjust the values for your environment.
# ----------------------------------------------------------------------------

# PostgreSQL connection (async driver: asyncpg)
DATABASE_URL=postgresql+asyncpg://topkapi:topkapi@localhost:5432/topkapi_qr

# --- JWT secrets -------------------------------------------------------------
# Generate strong random values, e.g.:  openssl rand -hex 32
# AUTH_SECRET signs user login tokens (long-lived sessions).
# QR_SECRET   signs the short-lived kiosk QR tokens (separate key on purpose).
AUTH_SECRET=change-me-to-a-long-random-string-for-auth
QR_SECRET=change-me-to-a-DIFFERENT-long-random-string-for-qr

# Access token lifetime for teacher/admin logins (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=720

# QR token lifetime (seconds) — the "15 second rule"
QR_TOKEN_TTL_SECONDS=15

# Comma separated list of allowed CORS origins (kiosk + admin tools)
CORS_ORIGINS=http://localhost:5173,http://localhost:19006

# Timezone used to decide the calendar "day" for attendance toggling.
# All storage is UTC; this only controls the day boundary for business logic.
ATTENDANCE_TIMEZONE=Europe/Istanbul

# Optional bootstrap admin (created on first startup if it does not exist)
BOOTSTRAP_ADMIN_EMAIL=admin@topkapi.k12.tr
BOOTSTRAP_ADMIN_PASSWORD=ChangeThisAdminPassword123!
BOOTSTRAP_ADMIN_NAME=System Admin
