# ============================================================================
# Production environment for docker-compose.prod.yml
# Copy to .env.prod and fill in REAL values. NEVER commit .env.prod.
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
# ============================================================================

# --- Domains (must point to this server via DNS A records) ------------------
API_DOMAIN=api.okulunuz.com
KIOSK_DOMAIN=kiosk.okulunuz.com
PANEL_DOMAIN=panel.okulunuz.com

# Email used for Let's Encrypt certificate registration / expiry notices.
ACME_EMAIL=bilgi@okulunuz.com

# --- Database ---------------------------------------------------------------
POSTGRES_USER=topkapi
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=topkapi_qr

# --- JWT secrets (generate each with: openssl rand -hex 32) -----------------
AUTH_SECRET=CHANGE_ME_run_openssl_rand_hex_32
QR_SECRET=CHANGE_ME_DIFFERENT_openssl_rand_hex_32

# --- Business rules ---------------------------------------------------------
QR_TOKEN_TTL_SECONDS=15
ACCESS_TOKEN_EXPIRE_MINUTES=720
ATTENDANCE_TIMEZONE=Europe/Istanbul

# --- Bootstrap admin (created on first boot; change password after login) ---
BOOTSTRAP_ADMIN_EMAIL=admin@okulunuz.com
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password
BOOTSTRAP_ADMIN_NAME=Okul Yoneticisi
