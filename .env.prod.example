# ============================================================================
# Production environment for docker-compose.prod.yml
# Copy to .env.prod and fill in REAL values. NEVER commit .env.prod.
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
# ============================================================================

# --- Domains (must point to this server via DNS A records) ------------------
API_DOMAIN=api.okulunuz.com
KIOSK_DOMAIN=kiosk.okulunuz.com
PANEL_DOMAIN=panel.okulunuz.com
APP_DOMAIN=app.okulunuz.com           # teacher PWA ("Ana Ekrana Ekle")

# Email used for Let's Encrypt certificate registration / expiry notices.
ACME_EMAIL=bilgi@okulunuz.com

# --- Database ---------------------------------------------------------------
POSTGRES_USER=topkapi
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=topkapi_qr

# --- JWT secrets (generate each with: openssl rand -hex 32) -----------------
# ZORUNLU: üçü de farklı, en az 16 karakter ve örnek/placeholder olmamalı.
# Aksi halde backend güvenlik denetimi nedeniyle ÜRETİMDE BAŞLAMAZ.
AUTH_SECRET=CHANGE_ME_run_openssl_rand_hex_32
REFRESH_SECRET=CHANGE_ME_DIFFERENT_openssl_rand_hex_32
QR_SECRET=CHANGE_ME_THIRD_openssl_rand_hex_32

# Ortam: production (varsayılan) güvenlik denetimini zorunlu kılar.
# Sadece yerel/geliştirme için 'development' yapın.
APP_ENV=production

# --- Business rules ---------------------------------------------------------
QR_TOKEN_TTL_SECONDS=15
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=365
ATTENDANCE_TIMEZONE=Europe/Istanbul

# --- Bootstrap admin (created on first boot; change password after login) ---
BOOTSTRAP_ADMIN_EMAIL=admin@okulunuz.com
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password
BOOTSTRAP_ADMIN_NAME=Okul Yoneticisi

# --- Web Push bildirimleri (İSTEĞE BAĞLI) -----------------------------------
# Boş bırakılırsa bildirim özelliği tamamen kapalı kalır (uygulama normal çalışır).
# Açmak için backend container'ında BİR KEZ anahtar üretin ve çıktıyı buraya yapıştırın:
#   docker compose -f docker-compose.prod.yml exec backend python -m app.tools.vapid_keys
# VAPID_PRIVATE_KEY gizli bir anahtardır (AUTH_SECRET gibi saklayın), paylaşmayın.
# PEM bloklarını tek satırda, satır sonları \n ile kaçışlı şekilde girin (araç böyle basar).
# VAPID_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# VAPID_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# VAPID_SUBJECT=mailto:topkapiokullariai@gmail.com
